# --- Project Environment Variables ---
# Copy this file to `project.env` and edit it for your derived repository.

PROJECT_NAME='kc-secure-template-dev'
PROJECT_IMAGE="${PROJECT_NAME}:local"

# Dockerfile image settings
PROJECT_DOCKERFILE='Dockerfile'
DEV_BASE_IMAGE='debian:bookworm-slim'
DEV_GO_VERSION='1.26.1'
DEV_GO_IMAGE="golang:${DEV_GO_VERSION}-bookworm"

# Security Scanners
DEV_SCAN_GITLEAKS_IMAGE='ghcr.io/gitleaks/gitleaks:v8.30.1'
DEV_SCAN_ACTIONLINT_IMAGE='rhysd/actionlint:1.7.12'
DEV_SCAN_TRIVY_IMAGE='aquasec/trivy:0.67.2'
DEV_SCAN_SYFT_IMAGE='anchore/syft:v1.42.3'
DEV_SCAN_GRYPE_IMAGE='anchore/grype:v0.110.0'

# Optional Terraform settings
DEV_TERRAFORM_IMAGE='hashicorp/terraform:1.14.8'
DEV_TERRAFORM_GITHUB_PROVIDER_VERSION='6.11.1'

# Source the SHA checksum lockfile for these pinned tooling versions
# (The lockfile is updated via `make update`)
. ./config/lockfile.env
